  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"radmir140606\",\n  \"email\": \"radmir140606@icloud.com\",\n  \"password\": \"securePass123\",\n  \"password2\": \"securePass123\"\n}"
            }
          },
          "response": [
            {
              "name": "Register Success",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"access\": \"eyJ...\",\n  \"refresh\": \"eyJ...\",\n  \"user\": {\n    \"id\": 1,\n    \"username\": \"radmir140606\",\n    \"email\": \"radmir140606@icloud.com\",\n    \"date_joined\": \"2024-01-01T00:00:00Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access);",
                  "pm.collectionVariables.set('refresh_token', json.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"radmir140606\",\n  \"password\": \"securePass123\"\n}"
            }
          },
          "response": [
            {
              "name": "Login Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"access\": \"eyJ...\",\n  \"refresh\": \"eyJ...\",\n  \"user\": {\n    \"id\": 1,\n    \"username\": \"radmir140606\",\n    \"email\": \"radmir140606@icloud.com\",\n    \"date_joined\": \"2024-01-01T00:00:00Z\"\n  }\n}"
            },
            {
              "name": "Login Failed",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"non_field_errors\": [\"Invalid username or password.\"]\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/auth/logout/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          },
          "response": [
            {
              "name": "Logout Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"detail\": \"Successfully logged out.\"\n}"
            }
          ]
        }
      ]
    },
